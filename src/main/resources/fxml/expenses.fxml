<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.openjfx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="12" style="-fx-background-color:#f4f7fb;-fx-padding:4 0 0 0;">

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="💰  Expense Tracker (Admin Only)"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="filterCategoryCombo" prefWidth="160"/>
        <Button text="➕ Add Expense"
                style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-cursor:hand;"
                onAction="#handleAdd"/>
        <Button text="✏️ Edit"
                style="-fx-background-color:#ecf0f1;-fx-text-fill:#2c3e50;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-border-color:#bdc3c7;-fx-cursor:hand;"
                onAction="#handleEdit"/>
        <Button text="🗑 Delete"
                style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-cursor:hand;"
                onAction="#handleDelete"/>
    </HBox>

    <Label fx:id="totalMonthLabel" text="This Month Total: ₹ 0.00"
           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#e74c3c;"/>

    <TableView fx:id="expenseTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;">
        <columns>
            <TableColumn fx:id="colTitle"    text="Title"       prefWidth="180" minWidth="160" resizable="false"/>
            <TableColumn fx:id="colCategory" text="Category"    prefWidth="140" minWidth="130" resizable="false"/>
            <TableColumn fx:id="colAmount"   text="Amount (₹)"  prefWidth="120" minWidth="110" resizable="false"/>
            <TableColumn fx:id="colDate"     text="Date"        prefWidth="110" minWidth="100" resizable="false"/>
            <TableColumn fx:id="colApproved" text="Approved By" prefWidth="140" minWidth="130" resizable="false"/>
            <TableColumn fx:id="colDesc"     text="Description" prefWidth="200" minWidth="180" resizable="false"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>

    <VBox fx:id="formPane"
          style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;-fx-padding:16;"
          spacing="12" visible="false" managed="false">
        <Label fx:id="formTitleLabel" text="Add Expense"
               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Separator/>
        <GridPane hgap="12" vgap="8">
            <Label text="Title:"        GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="titleField"     GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Category:"     GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <ComboBox fx:id="categoryCombo"   GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="180"/>
            <Label text="Amount (₹):"  GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="amountField"    GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Date:"         GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <DatePicker fx:id="datePicker"    GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="180"/>
            <Label text="Approved By:"  GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="approvedByField" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Receipt Ref:"  GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="receiptRefField" GridPane.rowIndex="2" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Description:"  GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextArea fx:id="descArea"        GridPane.rowIndex="3" GridPane.columnIndex="1"
                      GridPane.columnSpan="3" prefRowCount="2"
                      style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
        </GridPane>
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button text="💾 Save"   style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;" onAction="#handleSave"/>
            <Button text="✖ Cancel" style="-fx-background-color:#ecf0f1;-fx-text-fill:#2c3e50;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;" onAction="#handleCancel"/>
        </HBox>
    </VBox>
</VBox>
