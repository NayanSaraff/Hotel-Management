<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.openjfx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="12" style="-fx-background-color:#f4f7fb;-fx-padding:4 0 0 0;">

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="👥  Customer Management"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search by name, phone, email…" prefWidth="260"
                   style="-fx-background-color:white;-fx-border-color:#dde3eb;-fx-border-radius:20;-fx-background-radius:20;-fx-padding:7 14;"/>
        <Button text="➕ Add Customer"
                style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-cursor:hand;"
                onAction="#handleAdd"/>
        <Button text="✏️ Edit"
                style="-fx-background-color:#ecf0f1;-fx-text-fill:#2c3e50;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-border-color:#bdc3c7;-fx-cursor:hand;"
                onAction="#handleEdit"/>
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;">
        <columns>
            <TableColumn fx:id="colName"        text="Full Name"    prefWidth="180" minWidth="160"/>
            <TableColumn fx:id="colPhone"       text="Phone"        prefWidth="130" minWidth="120"/>
            <TableColumn fx:id="colEmail"       text="Email"        prefWidth="200" minWidth="180"/>
            <TableColumn fx:id="colCity"        text="City"         prefWidth="120" minWidth="100"/>
            <TableColumn fx:id="colNationality" text="Nationality"  prefWidth="110" minWidth="100"/>
            <TableColumn fx:id="colIdType"      text="ID Type"      prefWidth="120" minWidth="100"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <VBox fx:id="formPane"
          style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;-fx-padding:16;"
          spacing="12" visible="false" managed="false">
        <Label fx:id="formTitleLabel" text="Add Customer"
               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Separator/>
        <GridPane hgap="12" vgap="8">
            <Label text="First Name:"   GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="180" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Last Name:"    GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="lastNameField"  GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="180" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Email:"        GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="emailField"     GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Phone:"        GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="phoneField"     GridPane.rowIndex="1" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="City:"         GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="cityField"      GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="State:"        GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="stateField"     GridPane.rowIndex="2" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Country:"      GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="countryField"   GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="PIN Code:"     GridPane.rowIndex="3" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="pinField"       GridPane.rowIndex="3" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="ID Type:"      GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <ComboBox fx:id="idTypeCombo"     GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="180"/>
            <Label text="ID Number:"    GridPane.rowIndex="4" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="idNumberField"  GridPane.rowIndex="4" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Date of Birth:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <DatePicker fx:id="dobPicker"     GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="180"/>
            <Label text="Nationality:"  GridPane.rowIndex="5" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="nationalityField" GridPane.rowIndex="5" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Address:"      GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextArea fx:id="addressArea" GridPane.rowIndex="6" GridPane.columnIndex="1"
                      GridPane.columnSpan="3" prefRowCount="2"
                      style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
        </GridPane>
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button text="💾 Save"
                    style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;"
                    onAction="#handleSave"/>
            <Button text="✖ Cancel"
                    style="-fx-background-color:#ecf0f1;-fx-text-fill:#2c3e50;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;"
                    onAction="#handleCancel"/>
        </HBox>
    </VBox>
</VBox>
