<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.openjfx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="12" style="-fx-background-color:#f4f7fb;-fx-padding:4 0 0 0;">

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="💳  Payment History"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search by booking ref, mode…"
                   prefWidth="260"
                   style="-fx-background-color:white;-fx-border-color:#dde3eb;-fx-border-radius:20;-fx-background-radius:20;-fx-padding:7 14;"/>
        <Button text="🔄 Refresh" onAction="#handleRefresh"
                style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;"/>
    </HBox>

    <Label fx:id="totalLabel" text="Total Received: ₹ 0.00"
           style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>

    <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;">
        <columns>
            <TableColumn fx:id="colBookingRef"  text="Booking Ref"    prefWidth="140" minWidth="140"/>
            <TableColumn fx:id="colDate"        text="Payment Date"   prefWidth="160" minWidth="160"/>
            <TableColumn fx:id="colAmount"      text="Amount (₹)"     prefWidth="120" minWidth="120"/>
            <TableColumn fx:id="colMode"        text="Mode"           prefWidth="120" minWidth="120"/>
            <TableColumn fx:id="colType"        text="Type"           prefWidth="100" minWidth="100"/>
            <TableColumn fx:id="colTransaction" text="Transaction ID" prefWidth="150" minWidth="150"/>
            <TableColumn fx:id="colRemarks"     text="Remarks"        prefWidth="180" minWidth="180"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
