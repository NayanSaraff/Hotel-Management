<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.openjfx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="12" style="-fx-background-color:#f4f7fb;-fx-padding:4 0 0 0;">

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="🛏  Room Management"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search rooms…" prefWidth="220"
                   style="-fx-background-color:white;-fx-border-color:#dde3eb;-fx-border-radius:20;-fx-background-radius:20;-fx-padding:7 14;"/>
        <Button fx:id="addButton" text="➕ Add Room"
                style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-cursor:hand;"
                onAction="#handleAdd"/>
        <Button text="✎ Edit"
                style="-fx-background-color:#ecf0f1;-fx-text-fill:#2c3e50;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-border-color:#bdc3c7;-fx-cursor:hand;"
                onAction="#handleEdit"/>
        <Button fx:id="deleteButton" text="🗑 Delete"
                style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 16;-fx-background-radius:8;-fx-cursor:hand;"
                onAction="#handleDelete" disable="true"/>
    </HBox>

    <TableView fx:id="roomTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;">
        <columns>
            <TableColumn fx:id="colRoomNumber" text="Room No."  prefWidth="90"  minWidth="80"/>
            <TableColumn fx:id="colCategory"   text="Category" prefWidth="110" minWidth="100"/>
            <TableColumn fx:id="colFloor"      text="Floor"    prefWidth="65"  minWidth="60"/>
            <TableColumn fx:id="colCapacity"   text="Capacity" prefWidth="80"  minWidth="70"/>
            <TableColumn fx:id="colBedType"    text="Bed Type" prefWidth="110" minWidth="100"/>
            <TableColumn fx:id="colPrice"      text="₹/Night"  prefWidth="110" minWidth="100"/>
            <TableColumn fx:id="colStatus"     text="Status"   prefWidth="130" minWidth="120"/>
        </columns>
        <placeholder>
            <Label text="No data available." style="-fx-text-fill:#aaa;-fx-font-size:13px;"/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <VBox fx:id="formPane" style="-fx-background-color:white;-fx-background-radius:10;-fx-border-color:#dde3eb;-fx-border-radius:10;-fx-padding:16;" spacing="12">
        <Label fx:id="formTitleLabel" text="Add New Room"
               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a3c5c;"/>
        <Separator/>
        <GridPane hgap="12" vgap="8">
            <Label text="Room Number:"  GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="roomNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="180" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Category:"     GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <ComboBox fx:id="categoryCombo" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="180"/>
            <Label text="Floor:"        GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="floorField" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Capacity:"     GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="capacityField" GridPane.rowIndex="1" GridPane.columnIndex="3" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Price/Night:"  GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextField fx:id="priceField" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
            <Label text="Status:"       GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <ComboBox fx:id="statusCombo" GridPane.rowIndex="2" GridPane.columnIndex="3" prefWidth="180"/>
            <Label text="Bed Type:"     GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <ComboBox fx:id="bedTypeCombo" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="180"/>
            <Label text="Amenities:"    GridPane.rowIndex="3" GridPane.columnIndex="2" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <HBox spacing="12" GridPane.rowIndex="3" GridPane.columnIndex="3">
                <CheckBox fx:id="acCheckBox" text="AC"/>
                <CheckBox fx:id="wifiCheckBox" text="WiFi"/>
                <CheckBox fx:id="tvCheckBox" text="TV"/>
            </HBox>
            <Label text="Description:"  GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight:bold;-fx-text-fill:#566573;"/>
            <TextArea fx:id="descriptionArea" GridPane.rowIndex="4" GridPane.columnIndex="1"
                      GridPane.columnSpan="3" prefRowCount="2"
                      style="-fx-background-color:#f8fafc;-fx-border-color:#dde3eb;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:7 10;"/>
        </GridPane>
        <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Button fx:id="saveButton" text="💾 Save"
                    style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;"
                    onAction="#handleSave"/>
                <Button fx:id="cancelButton" text="✖ Cancel"
                    style="-fx-background-color:#ecf0f1;-fx-text-fill:#2c3e50;-fx-font-weight:bold;-fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;"
                    onAction="#handleCancel"/>
        </HBox>
    </VBox>
</VBox>
