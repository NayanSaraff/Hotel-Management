<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.openjfx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="login-bg"
           prefWidth="500" prefHeight="400">

    <VBox fx:id="loginCard" styleClass="login-card"
          alignment="CENTER" spacing="16" maxWidth="380" maxHeight="420">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Logo / Title -->
        <VBox alignment="CENTER" spacing="1">
            <ImageView fx:id="logoImageView" fitWidth="110" fitHeight="110" preserveRatio="true" smooth="true"/>
            <Label text="The Marcelli" styleClass="login-title"/>
            <Label text="Sign in to your account" styleClass="login-subtitle"/>
        </VBox>

        <Separator/>

        <!-- Username -->
        <VBox spacing="4">
            <Label text="Username" styleClass="form-label"/>
            <TextField fx:id="usernameField" promptText="Enter username"
                       styleClass="login-input"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="4">
            <Label text="Password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter password"
                           styleClass="login-input"/>
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

        <!-- Login Button -->
        <Button fx:id="loginButton" text="Sign In"
                styleClass="btn-primary" maxWidth="Infinity"
                onAction="#handleLogin"/>

        <ProgressIndicator fx:id="spinner" maxWidth="30" maxHeight="30"/>
    </VBox>
</StackPane>
